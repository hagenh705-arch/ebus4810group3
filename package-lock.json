import { useState, useContext, useEffect } from 'react';
import { Bar } from 'react-chartjs-2';
import {
  Chart as ChartJS, CategoryScale, LinearScale, BarElement,
  LineElement, PointElement, Title, Tooltip, Legend, Filler
} from 'chart.js';
import Modal from '../components/Modal';
import { ToastContext } from '../App';
import './Projections.css';

ChartJS.register(CategoryScale, LinearScale, BarElement, LineElement, PointElement, Title, Tooltip, Legend, Filler);

function calcData(p) {
  const { inv, rev, cost, grow, mo, disc } = p;
  const labels = [], revenues = [], profits = [], cumulative = [];
  let cum = -inv, npv = -inv, be = null;
  const md = disc / 100 / 12;
  for (let m = 1; m <= mo; m++) {
    const r = Math.round(rev * Math.pow(1 + grow / 100, m - 1));
    const pr = r - cost;
    cum += pr;
    npv += md > 0 ? pr / Math.pow(1 + md, m) : pr;
    if (be === null && cum >= 0) be = m;
    labels.push('M' + m);
    revenues.push(r);
    profits.push(Math.round(pr));
    cumulative.push(Math.round(cum));
  }
  return {
    labels, revenues, profits, cumulative,
    totalRev: revenues.reduce((a, b) => a + b, 0),
    netProfit: cum, npv, roi: inv > 0 ? (cum / inv) * 100 : 0, be
  };
}

export default function Projections({ projections, setProjections, pendingProjId, clearPending }) {
  const toast = useContext(ToastContext);
  const [selId, setSelId] = useState(null);
  const [form, setForm] = useState({});
  const [modal, setModal] = useState(null);

  // Auto-select a projection when navigated here from Data page
  useEffect(() => {
    if (pendingProjId) {
      const p = projections.find(x => x.id === pendingProjId);
      if (p) { selectProj(p); clearPending(); }
    }
  }, [pendingProjId, projections]);

  const setField = (key, val) => setForm(f => ({ ...f, [key]: val }));
  const sel = projections.find(p => p.id === selId);

  const selectProj = (p) => {
    setSelId(p.id);
    setForm({ inv: p.inv, rev: p.rev, cost: p.cost, grow: p.grow, mo: p.mo, disc: p.disc });
  };

  const moVal = Math.min(60, Math.max(1, +form.mo || 12));
  const computed = sel ? calcData({ ...sel, ...form, mo: moVal }) : null;

  const skip = computed ? Math.max(1, Math.floor(computed.labels.length / 12)) : 1;

  const chartData = computed ? {
    labels: computed.labels.map((l, i) => i % skip === 0 ? l : ''),
    datasets: [
      { type: 'bar',  label: 'Monthly Revenue', data: computed.revenues,   backgroundColor: 'rgba(128,177,213,0.75)', borderRadius: 4, order: 2 },
      { type: 'bar',  label: 'Monthly Profit',  data: computed.profits,    backgroundColor: 'rgba(42,122,75,0.65)',   borderRadius: 4, order: 2 },
      { type: 'line', label: 'Cumulative',       data: computed.cumulative, borderColor: '#0d1b4b', backgroundColor: 'rgba(13,27,75,0.07)', borderWidth: 2, pointRadius: 0, fill: true, order: 1 },
    ],
  } : null;

  const chartOptions = {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { labels: { font: { size: 11 }, boxWidth: 12 } } },
    scales: {
      x: { grid: { display: false }, ticks: { font: { size: 10 } } },
      y: { grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { font: { size: 10 }, callback: v => '$' + (Math.abs(v) >= 1000 ? (v / 1000).toFixed(0) + 'k' : v) } },
    },
  };

  const today = () => { const d = new Date(); return `${d.getMonth()+1}/${d.getDate()}/${String(d.getFullYear()).slice(-2)}`; };
  const fmt = n => '$' + Math.round(n).toLocaleString();

  const newProj = () => setModal({ title: 'New Projection', desc: 'Name your projection', ph: 'e.g. Q3 Revenue Forecast', cb: name => {
    const id = Date.now();
    const p = { id, name, date: today(), inv: 50000, rev: 8000, cost: 5000, grow: 3, mo: 24, disc: 8 };
    setProjections(ps => [p, ...ps]);
    selectProj(p);
  }});

  const renameProj = () => { if (!sel) return; setModal({ title: 'Rename', desc: 'Enter a new name', ph: sel.name, cb: name => {
    setProjections(ps => ps.map(p => p.id === selId ? { ...p, name } : p));
  }}); };

  const updateProj = () => {
    if (!sel) { toast('Select a projection first'); return; }
    setProjections(ps => ps.map(p => p.id === selId ? { ...p, ...form, mo: moVal, date: today() } : p));
    toast('Projection saved!');
  };

  const deleteProj = () => {
    if (!sel) { toast('Select a projection first'); return; }
    if (!window.confirm(`Delete "${sel.name}"?`)) return;
    setProjections(ps => ps.filter(p => p.id !== selId));
    setSelId(null);
  };

  const exportProj = () => {
    if (!sel) { toast('Select a projection first'); return; }
    const p = { ...sel, ...form, mo: moVal };
    let csv = 'Month,Revenue,Costs,Profit,Cumulative\n', cum = -p.inv;
    for (let m = 1; m <= p.mo; m++) {
      const r = Math.round(p.rev * Math.pow(1 + p.grow / 100, m - 1));
      const pr = r - p.cost; cum += pr;
      csv += `${m},${r},${p.cost},${pr},${Math.round(cum)}\n`;
    }
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([csv], { type: 'text/csv' }));
    a.download = sel.name.replace(/\s+/g, '_') + '.csv';
    a.click();
    toast('Exported!');
  };

  return (
    <div>
      <div className="page-header">
        <h1 className="page-title">Projections</h1>
        <div className="btn-row">
          <button className="btn btn-primary"   onClick={newProj}>+ New Projection</button>
          <button className="btn btn-secondary" onClick={updateProj}>Update</button>
          <button className="btn btn-secondary" onClick={exportProj}>Export CSV</button>
          <button className="btn btn-danger"    onClick={deleteProj}>Delete</button>
        </div>
      </div>

      <div className="proj-list">
        {projections.map(p => (
          <div key={p.id} className={`proj-row ${selId === p.id ? 'selected' : ''}`} onClick={() => selectProj(p)}>
            <div>
              <div className="proj-name">{p.name}</div>
              <div className="proj-meta">Updated {p.date}</div>
            </div>
            <div className="proj-date">{p.date}</div>
          </div>
        ))}
      </div>

      {sel && computed && (
        <div className="proj-detail card">
          <div className="proj-detail-header">
            <div>
              <div className="proj-detail-title">{sel.name}</div>
              <div className="proj-rename" onClick={renameProj}>click to rename</div>
            </div>
            <button className="btn btn-secondary" onClick={() => selectProj(sel)}>Reset</button>
          </div>

          <div className="proj-inputs">
            {[
              { label: 'Initial Investment ($)', key: 'inv' },
              { label: 'Monthly Revenue ($)',    key: 'rev' },
              { label: 'Monthly Costs ($)',      key: 'cost' },
              { label: 'Growth Rate (%/mo)',     key: 'grow' },
              { label: 'Period (months)',        key: 'mo' },
              { label: 'Discount Rate (%/yr)',   key: 'disc' },
            ].map(({ label, key }) => (
              <div className="field" key={key}>
                <label>{label}</label>
                <input type="number" value={form[key] ?? ''} onChange={e => setField(key, e.target.value)} />
              </div>
            ))}
          </div>

          <div className="chart-area">
            <Bar data={chartData} options={chartOptions} />
          </div>

          <div className="results-grid">
            {[
              { label: 'Total Revenue',   val: fmt(computed.totalRev),  cls: '' },
              { label: 'Net Profit',      val: fmt(computed.netProfit), cls: computed.netProfit >= 0 ? 'pos' : 'neg' },
              { label: 'NPV',             val: fmt(computed.npv),       cls: computed.npv >= 0 ? 'pos' : 'neg' },
              { label: 'Break Even',      val: computed.be ? 'Mo ' + computed.be : 'N/A', cls: '' },
              { label: 'ROI',             val: computed.roi.toFixed(1) + '%', cls: computed.roi >= 0 ? 'pos' : 'neg' },
              { label: 'Investment',      val: fmt(+form.inv || 0),     cls: '' },
              { label: 'Avg Mo. Revenue', val: fmt(computed.totalRev / moVal), cls: '' },
              { label: 'Period',          val: moVal + ' mo',           cls: '' },
            ].map(({ label, val, cls }) => (
              <div className="result-card" key={label}>
                <div className="result-label">{label}</div>
                <div className={`result-value ${cls}`}>{val}</div>
              </div>
            ))}
          </div>
        </div>
      )}

      {modal && (
        <Modal title={modal.title} description={modal.desc} placeholder={modal.ph}
          onConfirm={modal.cb} onClose={() => setModal(null)} />
      )}
    </div>
  );
}
